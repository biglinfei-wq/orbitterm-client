{
  "name": "orbitterm-app",
  "private": true,
  "version": "0.1.84",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.website.config.ts",
    "tauri": "tauri",
    "build": "tsc -b && vite build",
    "build:web": "tsc -p website/tsconfig.json --noEmit && vite build --config vite.website.config.ts",
    "build:linux:docker:x64": "bash scripts/local-build/build-linux-docker.sh --arch amd64",
    "build:linux:docker:x64:all": "bash scripts/local-build/build-linux-docker.sh --arch amd64 --linux-targets deb,rpm,appimage",
    "build:linux:docker:arm64": "bash scripts/local-build/build-linux-docker.sh --arch arm64",
    "build:linux:docker:arm64:all": "bash scripts/local-build/build-linux-docker.sh --arch arm64 --linux-targets deb,rpm,appimage",
    "build:macos:arm64": "bash scripts/local-build/build-macos-host.sh --arch arm64",
    "build:macos:x64": "bash scripts/local-build/build-macos-host.sh --arch x64",
    "setup:mobile:local": "bash scripts/local-build/setup-mobile.sh",
    "build:android:apk:debug": "bash scripts/local-build/build-android.sh",
    "build:ios:sim:debug": "bash scripts/local-build/build-ios.sh",
    "build:local:all": "bash scripts/local-build/build-all.sh",
    "build:local:preflight": "bash scripts/local-build/preflight.sh",
    "preview": "vite preview",
    "preview:web": "vite preview --config vite.website.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p website/tsconfig.json --noEmit",
    "test:client": "vitest run src/services/cloudSync.client.e2e.test.ts",
    "test": "vitest run",
    "generate:icons": "python3 scripts/generate_tauri_icons.py"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inconsolata": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@hookform/resolvers": "^3.10.0",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.1",
    "react-resizable-panels": "^4.7.6",
    "sonner": "^2.0.7",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-webgl": "^0.16.0",
    "zod": "^3.24.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^5.4.14",
    "vitest": "^2.1.9"
  }
}
